# Example environment variables for dawnbook.
# Copy to .env and fill in real values. .env is git-ignored.
# For production secrets, use: wrangler pages secret put <NAME>

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs)
# Authorized redirect URI must match the deployment domain + /api/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
